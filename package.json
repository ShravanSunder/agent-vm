{
	"name": "agent-vm-workspace",
	"version": "0.0.1",
	"private": true,
	"description": "Sandboxed VM controller, worker, and gateway packages for autonomous coding agents",
	"author": "Shravan Sunder <ShravanSunder@users.noreply.github.com>",
	"type": "module",
	"scripts": {
		"build": "pnpm -r build",
		"clean": "git clean -fdX packages",
		"lint": "oxlint .",
		"lint:fix": "oxlint --fix",
		"lint:types": "oxlint --type-aware .",
		"fmt": "oxfmt .",
		"fmt:check": "oxfmt --check .",
		"typecheck": "tsc -p tsconfig.json --noEmit && pnpm -r typecheck",
		"check": "pnpm lint:types && pnpm fmt:check && pnpm typecheck",
		"test": "pnpm test:unit",
		"test:unit": "vitest run --config vitest.config.ts",
		"test:integration": "vitest run --config vitest.integration.config.ts",
		"test:smoke": "vitest run --config vitest.smoke.config.ts",
		"test:watch": "vitest",
		"perf:gondolin-vfs": "node scripts/perf/gondolin-vfs-benchmark.ts",
		"perf:worker-git": "node scripts/perf/gondolin-worker-git-benchmark.ts"
	},
	"devDependencies": {
		"@types/node": "^25.6.0",
		"oxfmt": "^0.44.0",
		"oxlint": "^1.59.0",
		"oxlint-tsgolint": "^0.20.0",
		"tasuku": "^2.3.0",
		"tsdown": "^0.15.4",
		"typescript": "^6.0.2",
		"vite": "^8.0.8",
		"vitest": "^4.1.4"
	},
	"engines": {
		"node": ">=24"
	},
	"packageManager": "pnpm@10.33.0",
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	}
}
