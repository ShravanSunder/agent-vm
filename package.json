{
	"name": "agent-vm",
	"version": "0.0.1",
	"private": true,
	"description": "Gondolin-based VM controller and OpenClaw integration",
	"type": "module",
	"scripts": {
		"build": "pnpm -r build",
		"changeset": "changeset",
		"clean": "git clean -fdX packages",
		"lint": "oxlint .",
		"lint:fix": "oxlint --fix",
		"lint:types": "oxlint --type-aware .",
		"fmt": "oxfmt .",
		"fmt:check": "oxfmt --check .",
		"typecheck": "tsc -p tsconfig.json --noEmit && pnpm -r typecheck",
		"check": "pnpm lint:types && pnpm fmt:check && pnpm typecheck",
		"test": "vitest run",
		"test:integration": "vitest run --config vitest.integration.config.ts",
		"test:watch": "vitest",
		"version:packages": "changeset version",
		"publish:packages": "changeset publish"
	},
	"devDependencies": {
		"@changesets/cli": "^2.29.7",
		"@types/node": "^25.6.0",
		"oxfmt": "^0.44.0",
		"oxlint": "^1.59.0",
		"oxlint-tsgolint": "^0.20.0",
		"tasuku": "^2.3.0",
		"tsdown": "^0.15.4",
		"typescript": "^6.0.2",
		"vite": "latest",
		"vitest": "^4.1.4"
	},
	"engines": {
		"node": ">=24"
	},
	"packageManager": "pnpm@10.33.0",
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	}
}
