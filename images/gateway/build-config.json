{
	"arch": "aarch64",
	"oci": {
		"image": "docker.io/library/node:24-slim",
		"pullPolicy": "if-not-present"
	},
	"postBuild": {
		"commands": [
			"apt-get update && apt-get install -y git curl openssh-server python3 ca-certificates chromium",
			"npm install -g openclaw@2026.4.2",
			"useradd -m -s /bin/bash openclaw",
			"mkdir -p /home/openclaw/.openclaw /home/openclaw/workspace",
			"chown -R openclaw:openclaw /home/openclaw"
		]
	}
}
