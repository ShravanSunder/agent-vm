{
	"arch": "aarch64",
	"distro": "alpine",
	"alpine": {
		"version": "3.23.0",
		"kernelPackage": "linux-virt",
		"kernelImage": "vmlinuz-virt",
		"rootfsPackages": [],
		"initramfsPackages": []
	},
	"oci": {
		"image": "agent-vm-tool:latest",
		"pullPolicy": "never"
	},
	"rootfs": {
		"label": "tool-root",
		"sizeMb": 2048
	},
	"postBuild": {
		"commands": [
			"ln -sf /proc/self/fd /dev/fd 2>/dev/null || true",
			"update-ca-certificates",
			"mkdir -p /workspace /run/sshd"
		]
	}
}
