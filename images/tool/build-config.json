{
  "arch": "aarch64",
  "oci": {
    "image": "docker.io/library/node:24-slim",
    "pullPolicy": "if-not-present"
  },
  "postBuild": {
    "commands": [
      "apt-get update && apt-get install -y git curl openssh-server python3 python3-pip ca-certificates",
      "npm install -g @anthropic-ai/claude-code @openai/codex",
      "useradd -m -s /bin/bash sandbox",
      "mkdir -p /workspace",
      "chown sandbox:sandbox /workspace"
    ]
  }
}
