# agent-vm environment configuration
# 1Password token is stored in macOS Keychain by agent-vm init.
# This file is only needed for CI or non-macOS environments.

# === 1Password Service Account (CI/non-macOS only) ===
# On macOS, agent-vm init stores this in Keychain instead.
# OP_SERVICE_ACCOUNT_TOKEN=

# === Secret References (1Password op:// URIs) ===
# Override these if your vault structure differs from the defaults.
DISCORD_BOT_TOKEN_REF=op://agent-vm/agent-discord-app/bot-token
PERPLEXITY_API_KEY_REF=op://agent-vm/agent-perplexity/credential
OPENCLAW_GATEWAY_TOKEN_REF=op://agent-vm/agent-shravan-claw-gateway/password

# === Integration Testing (optional) ===
# OpenAI API key for model round-trip integration tests.
# Not used by the production system (which uses Codex OAuth).
OPEN_AI_TEST_KEY=
