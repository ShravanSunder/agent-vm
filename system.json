{
	"host": {
		"controllerPort": 18800,
		"secretsProvider": {
			"type": "1password",
			"tokenSource": {
				"type": "env",
				"envVar": "OP_SERVICE_ACCOUNT_TOKEN"
			}
		}
	},
	"cacheDir": "./cache",
	"images": {
		"gateway": {
			"buildConfig": "./images/gateway/build-config.json",
			"dockerfile": "./images/gateway/Dockerfile"
		},
		"tool": {
			"buildConfig": "./images/tool/build-config.json",
			"dockerfile": "./images/tool/Dockerfile"
		}
	},
	"zones": [
		{
			"id": "shravan",
			"gateway": {
				"memory": "2G",
				"cpus": 2,
				"port": 18791,
				"gatewayConfig": "./config/shravan/openclaw.json",
				"stateDir": "./state/shravan",
				"workspaceDir": "./workspaces/shravan"
			},
			"secrets": {
				"DISCORD_BOT_TOKEN": {
					"source": "1password",
					"injection": "env"
				},
				"PERPLEXITY_API_KEY": {
					"source": "1password",
					"injection": "http-mediation",
					"hosts": ["api.perplexity.ai"]
				},
				"OPENCLAW_GATEWAY_TOKEN": {
					"source": "1password",
					"injection": "env"
				}
			},
			"websocketBypass": [
				"gateway.discord.gg:443",
				"web.whatsapp.com:443",
				"g.whatsapp.net:443",
				"mmg.whatsapp.net:443",
				"media.whatsapp.net:443",
				"pps.whatsapp.net:443",
				"static.whatsapp.net:443"
			],
			"allowedHosts": [
				"api.openai.com",
				"auth.openai.com",
				"chatgpt.com",
				"api.perplexity.ai",
				"discord.com",
				"cdn.discordapp.com",
				"api.github.com",
				"registry.npmjs.org",
				"deb.debian.org",
				"security.debian.org",
				"clawhub.ai",
				"openclaw.ai",
				"docs.openclaw.ai"
			],
			"toolProfile": "standard"
		}
	],
	"toolProfiles": {
		"standard": {
			"memory": "1G",
			"cpus": 1,
			"workspaceRoot": "./workspaces/tools"
		}
	},
	"tcpPool": {
		"basePort": 19000,
		"size": 5
	}
}
