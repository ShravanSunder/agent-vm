{
	"host": {
		"controllerPort": 18800,
		"secretsProvider": {
			"type": "1password",
			"serviceAccountTokenEnv": "OP_SERVICE_ACCOUNT_TOKEN"
		}
	},
	"images": {
		"gateway": {
			"buildConfig": "./images/gateway/build-config.json",
			"postBuild": []
		},
		"tool": {
			"buildConfig": "./images/tool/build-config.json",
			"postBuild": []
		}
	},
	"zones": [
		{
			"id": "shravan",
			"gateway": {
				"memory": "2G",
				"cpus": 2,
				"port": 18791,
				"openclawConfig": "./config/shravan/openclaw.json",
				"stateDir": "./state/shravan",
				"workspaceDir": "./workspaces/shravan"
			},
			"secrets": {
				"ANTHROPIC_API_KEY": {
					"source": "1password",
					"ref": "op://AI/anthropic/api-key"
				},
				"DISCORD_BOT_TOKEN": {
					"source": "1password",
					"ref": "op://AI/discord-shravan/token"
				},
				"GITHUB_PAT": {
					"source": "1password",
					"ref": "op://AI/github-bot/pat"
				}
			},
			"allowedHosts": [
				"api.anthropic.com",
				"api.openai.com",
				"discord.com",
				"gateway.discord.gg",
				"web.whatsapp.com",
				"api.whatsapp.com",
				"api.github.com"
			],
			"toolProfile": "standard"
		}
	],
	"toolProfiles": {
		"standard": {
			"memory": "1G",
			"cpus": 1,
			"workspaceRoot": "./workspaces/tools"
		}
	},
	"tcpPool": {
		"basePort": 19000,
		"size": 5
	}
}
