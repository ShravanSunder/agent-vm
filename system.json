{
	"host": {
		"controllerPort": 18800,
		"secretsProvider": {
			"type": "1password",
			"tokenSource": {
				"type": "op-cli",
				"ref": "op://agent-vm/agent-1p-service-account/password"
			}
		}
	},
	"images": {
		"gateway": {
			"buildConfig": "./images/gateway/build-config.json",
			"postBuild": []
		},
		"tool": {
			"buildConfig": "./images/tool/build-config.json",
			"postBuild": []
		}
	},
	"zones": [
		{
			"id": "shravan",
			"gateway": {
				"memory": "2G",
				"cpus": 2,
				"port": 18791,
				"openclawConfig": "./config/shravan/openclaw.json",
				"stateDir": "./state/shravan",
				"workspaceDir": "./workspaces/shravan"
			},
			"secrets": {
				"DISCORD_BOT_TOKEN": {
					"source": "1password",
					"ref": "op://agent-vm/agent-discord-app/bot-token"
				}
			},
			"allowedHosts": [
				"api.anthropic.com",
				"statsig.anthropic.com",
				"sentry.io",
				"api.openai.com",
				"auth.openai.com",
				"discord.com",
				"gateway.discord.gg",
				"cdn.discordapp.com",
				"web.whatsapp.com",
				"*.whatsapp.net",
				"api.github.com",
				"registry.npmjs.org",
				"clawhub.ai",
				"openclaw.ai",
				"docs.openclaw.ai"
			],
			"toolProfile": "standard"
		}
	],
	"toolProfiles": {
		"standard": {
			"memory": "1G",
			"cpus": 1,
			"workspaceRoot": "./workspaces/tools"
		}
	},
	"tcpPool": {
		"basePort": 19000,
		"size": 5
	}
}
