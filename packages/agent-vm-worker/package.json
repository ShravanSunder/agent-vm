{
	"name": "@shravansunder/agent-vm-worker",
	"version": "0.0.4",
	"bin": {
		"agent-vm-worker": "./dist/main.js"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"test": "pnpm test:unit",
		"test:unit": "vitest run --root ../../ --config vitest.config.ts packages/agent-vm-worker/src",
		"test:integration": "vitest run --root ../../ --config vitest.integration.config.ts packages/agent-vm-worker/src",
		"test:smoke": "vitest run --root ../../ --config vitest.smoke.config.ts packages/agent-vm-worker/src",
		"start": "node ./dist/main.js"
	},
	"dependencies": {
		"@hono/node-server": "^1",
		"@hono/zod-validator": "^0.7.6",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@openai/codex-sdk": "^0.118.0",
		"cmd-ts": "^0.14.0",
		"execa": "^9.5.2",
		"hono": "^4",
		"zod": "^4",
		"zod-to-json-schema": "^3.24.1"
	},
	"devDependencies": {
		"vitest": "^4.1.4"
	}
}
