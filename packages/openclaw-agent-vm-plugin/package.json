{
	"name": "@shravansunder/openclaw-agent-vm-plugin",
	"version": "0.0.4",
	"files": [
		"dist"
	],
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsdown && cp openclaw.plugin.json sdk-validate.mjs dist/",
