{
	"name": "@agent-vm/openclaw-agent-vm-plugin",
	"version": "0.0.19",
	"author": "Shravan Sunder <ShravanSunder@users.noreply.github.com>",
	"files": [
		"dist"
	],
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"publishConfig": {
		"access": "restricted"
	},
	"scripts": {
		"build": "tsdown && cp openclaw.plugin.json sdk-validate.mjs dist/",
		"prepack": "pnpm -C ../.. build",
		"typecheck": "tsc -p tsconfig.json --noEmit"
	},
	"dependencies": {
		"@agent-vm/gondolin-adapter": "workspace:*"
	}
}
