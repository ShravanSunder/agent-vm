{
	"name": "@shravansunder/agent-vm",
	"version": "0.0.17",
	"bin": {
		"agent-vm": "./dist/cli/agent-vm-entrypoint.js"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "rm -rf dist && tsc -p tsconfig.build.json",
		"prepack": "pnpm -C ../.. build",
		"typecheck": "tsc -p tsconfig.json --noEmit"
	},
	"dependencies": {
		"@hono/node-server": "^1.19.14",
		"@shravansunder/agent-vm-worker": "workspace:*",
		"@shravansunder/gateway-interface": "workspace:*",
		"@shravansunder/gondolin-core": "workspace:*",
		"@shravansunder/openclaw-agent-vm-plugin": "workspace:*",
		"@shravansunder/openclaw-gateway": "workspace:*",
		"@shravansunder/worker-gateway": "workspace:*",
		"cmd-ts": "^0.14.0",
		"execa": "^9.5.2",
		"hono": "^4.12.14",
		"tasuku": "^2.3.0",
		"zod": "^4"
	}
}
